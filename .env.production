# 🚀 PAWSCORD Production Environment — Cloudflare Pages + Railway
# ⚠️ All variables use VITE_ prefix
# Frontend: https://pawscord.com  (Cloudflare Pages)
# Backend:  https://api.pawscord.com  (CNAME → Railway URL below)
# Railway direct URL: https://pawscord-repo-production.up.railway.app

# API Configuration
VITE_BACKEND_URL=https://api.pawscord.com
VITE_API_URL=https://api.pawscord.com
VITE_API_BASE_URL=https://api.pawscord.com
VITE_LOCAL_IP=pawscord.com
VITE_DJANGO_PORT=443
VITE_ENV=production

# 🌐 CF Pages base path (always '/' — don't use CDN URL here)
VITE_BASE_PATH=/

