# Cloudflare Pages SPA Redirects
# Note: Cloudflare Pages serves static assets BEFORE checking these rules.
# The /assets/* pass-through rule is omitted because it can interfere with
# CORS-mode requests (Sec-Fetch-Mode: cors), causing Cloudflare to return
# index.html instead of the actual JS/CSS files.
/static/*  /static/:splat  200
/icons/*   /icons/:splat   200
/service-worker.js  /service-worker.js  200
/sw.js  /sw.js  200
/manifest.webmanifest  /manifest.webmanifest  200
/registerSW.js  /registerSW.js  200

# SPA fallback - all other routes go to index.html
/*  /index.html  200
