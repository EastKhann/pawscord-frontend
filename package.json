{
    "name": "pawscord",
    "version": "1.1.249",
    "description": "Pawscord Sohbet Uygulamasi",
    "author": "Eastkhan",
    "private": true,
    "main": "public/electron.js",
    "homepage": "./",
    "dependencies": {
        "@capacitor/android": "^7.4.4",
        "@capacitor/app": "^7.0.0",
        "@capacitor/browser": "^7.0.0",
        "@capacitor/cli": "^7.4.4",
        "@capacitor/core": "^7.4.4",
        "@capacitor/haptics": "^8.0.2",
        "@capacitor/ios": "^7.4.4",
        "@capacitor/keyboard": "^8.0.3",
        "@capacitor/network": "^8.0.1",
        "@capacitor/push-notifications": "^7.0.0",
        "@capacitor/splash-screen": "^8.0.1",
        "@capacitor/status-bar": "^7.0.3",
        "@codetrix-studio/capacitor-google-auth": "^3.4.0-rc.4",
        "@hello-pangea/dnd": "^18.0.1",
        "@react-oauth/google": "^0.12.2",
        "@sentry/react": "^10.38.0",
        "@tiptap/extension-placeholder": "^3.12.1",
        "@tiptap/pm": "^3.12.1",
        "@tiptap/react": "^3.12.1",
        "@tiptap/starter-kit": "^3.12.1",
        "axios": "^1.13.4",
        "chart.js": "^4.5.1",
        "crypto-js": "^4.2.0",
        "dompurify": "^3.3.1",
        "electron-is-dev": "^3.0.1",
        "i18next": "^25.8.4",
        "i18next-browser-languagedetector": "^8.2.0",
        "idb": "^8.0.3",
        "jwt-decode": "^4.0.0",
        "qrcode": "^1.5.4",
        "qrcode.react": "^4.2.0",
        "react": "^19.2.0",
        "react-chartjs-2": "^5.3.1",
        "react-color": "^2.19.3",
        "react-dom": "^19.2.0",
        "react-draggable": "^4.5.0",
        "react-focus-lock": "^2.13.2",
        "react-i18next": "^16.5.4",
        "react-icons": "^5.5.0",
        "react-image-crop": "^11.0.10",
        "react-markdown": "^10.1.0",
        "react-player": "^3.4.0",
        "react-resizable": "^3.0.5",
        "react-router-dom": "^6.22.0",
        "react-syntax-highlighter": "^16.1.0",
        "react-toastify": "^11.0.5",
        "react-virtualized-auto-sizer": "^2.0.2",
        "react-window": "^1.8.10",
        "recharts": "^3.6.0",
        "rehype-raw": "^7.0.0",
        "remark-gfm": "^4.0.1",
        "spark-md5": "^3.0.2",
        "web-vitals": "^2.1.4",
        "zustand": "^5.0.9"
    },
    "devDependencies": {
        "@axe-core/react": "^4.10.1",
        "@fullhuman/postcss-purgecss": "^7.0.2",
        "@playwright/test": "^1.58.2",
        "@testing-library/dom": "^10.4.1",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/react": "^19.0.0",
        "@types/react-dom": "^19.0.0",
        "@vitejs/plugin-react": "^5.1.2",
        "@vitest/coverage-v8": "^4.0.18",
        "axe-core": "^4.11.1",
        "concurrently": "^8.2.2",
        "cross-env": "^7.0.3",
        "electron": "^35.7.5",
        "electron-builder": "24.13.3",
        "eslint": "^8.57.1",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-jsx-a11y": "^6.10.2",
        "eslint-plugin-prettier": "^5.5.5",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^7.0.1",
        "jsdom": "^28.0.0",
        "openapi-fetch": "^0.13.6",
        "openapi-typescript": "^7.6.1",
        "prettier": "^3.8.1",
        "rollup-plugin-visualizer": "^6.0.5",
        "sharp": "^0.34.5",
        "source-map-explorer": "^2.5.3",
        "stylelint": "^16.12.0",
        "stylelint-config-standard": "^37.0.0",
        "typescript": "^5.9.3",
        "vite": "^7.3.1",
        "vite-plugin-pwa": "^1.2.0",
        "vitest": "^4.0.18",
        "wait-on": "^7.2.0",
        "wrangler": "^4.4.0"
    },
    "scripts": {
        "start": "vite",
        "dev": "vite",
        "build": "vite build",
        "build:android": "vite build --config vite.config.android.js",
        "build:prod": "cross-env VITE_ENV=production vite build && node scripts/verify-build.js",
        "build:pages": "cross-env VITE_ENV=production VITE_BASE_PATH=/ VITE_OUT_DIR=dist vite build --mode production",
        "deploy:pages": "npm run build:pages && wrangler pages deploy dist --project-name=pawscord --commit-dirty=true",
        "verify": "node scripts/verify-build.js",
        "preview": "vite preview",
        "analyze": "source-map-explorer 'build/static/js/*.js'",
        "build:analyze": "npm run build && npm run analyze",
        "electron:dev": "concurrently \"cross-env BROWSER=none npm run dev\" \"wait-on http://localhost:3000 && electron .\"",
        "electron:build": "vite build --config vite.config.electron.js && electron-builder -w",
        "electron:build:debug": "vite build --config vite.config.electron.js && electron-builder -w --config electron-builder-debug.json",
        "electron:pack": "electron-builder -w",
        "build:publish": "npm run electron:build && node move-build.js",
        "build:publish:debug": "npm run electron:build:debug && node move-build.js",
        "logs": "electron view-logs.js",
        "audit:security": "npm audit --audit-level=high",
        "upload:r2": "node scripts/upload-builds-to-r2.js",
        "api:generate": "openapi-typescript http://localhost:8000/api/schema/?format=json -o src/api/schema.d.ts",
        "api:schema-check": "openapi-typescript http://localhost:8000/api/schema/?format=json -o /tmp/schema_check.d.ts && diff src/api/schema.d.ts /tmp/schema_check.d.ts && echo 'Schema unchanged' || (echo 'SCHEMA CHANGED — regenerate with npm run api:generate' && exit 1)",
        "release": "npm run electron:build && node scripts/upload-builds-to-r2.js",
        "lint:src-root": "node -e \"const fs=require('fs');const f=fs.readdirSync('src').filter(n=>fs.statSync('src/'+n).isFile()&&/\\.(js|jsx|ts|tsx)$/.test(n));if(f.length>10){console.error('src/ root has '+f.length+' files (max 10):',f.join(', '));process.exit(1);}else{console.log('src/ root OK: '+f.length+' files');}\"",
        "lint:css": "stylelint \"src/**/*.css\" --allow-empty-input",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "test:a11y": "vitest run --reporter=verbose src/__tests__/a11y/",
        "test:ui": "vitest --ui",
        "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,json,css}\"",
        "format:check": "prettier --check \"src/**/*.{js,jsx,ts,tsx,json,css}\"",
        "lint": "eslint src/ --ext .js,.jsx,.ts,.tsx",
        "lint:fix": "eslint src/ --ext .js,.jsx,.ts,.tsx --fix",
        "test:e2e": "playwright test",
        "test:e2e:ui": "playwright test --ui",
        "test:e2e:report": "playwright show-report",
        "size": "size-limit",
        "size:why": "size-limit --why",
        "test:mutation": "vitest run --reporter=verbose --bail 5 -- --experimental-vm-modules"
    },
    "build": {
        "appId": "com.dogukan.pawscord",
        "productName": "Pawscord",
        "files": [
            "build/**/*",
            "public/electron.js",
            "public/preload.js",
            "package.json"
        ],
        "compression": "store",
        "extraMetadata": {
            "main": "public/electron.js"
        },
        "directories": {
            "buildResources": "public",
            "output": "dist"
        },
        "win": {
            "target": "nsis",
            "icon": "public/logo.ico",
            "requestedExecutionLevel": "asInvoker"
        },
        "nsis": {
            "oneClick": false,
            "perMachine": false,
            "allowToChangeInstallationDirectory": true,
            "createDesktopShortcut": true,
            "createStartMenuShortcut": true,
            "deleteAppDataOnUninstall": false,
            "runAfterFinish": true,
            "differentialPackage": false,
            "include": "public/installer.nsh",
            "installerIcon": "public/logo.ico",
            "uninstallerIcon": "public/logo.ico",
            "installerHeaderIcon": "public/logo.ico",
            "artifactName": "Pawscord-Setup.${ext}",
            "shortcutName": "Pawscord",
            "uninstallDisplayName": "Pawscord",
            "menuCategory": false,
            "allowElevation": true,
            "warningsAsErrors": false
        }
    },
    "browserslist": {
        "production": [
            ">0.2%",
            "not dead",
            "not op_mini all"
        ],
        "development": [
            "last 1 chrome version",
            "last 1 firefox version",
            "last 1 safari version"
        ]
    },
    "size-limit": [
        {
            "path": "build/assets/*.js",
            "limit": "500 KB",
            "gzip": true
        },
        {
            "path": "build/assets/*.css",
            "limit": "100 KB",
            "gzip": true
        }
    ]
}
